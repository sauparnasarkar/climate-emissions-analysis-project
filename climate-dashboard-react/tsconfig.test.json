{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vitest/globals", "@testing-library/jest-dom", "vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Mirrors the Vite alias so tests type-check design-system imports too */
    "paths": {
      "design-system": ["../../design-system/src"],
      "design-system/*": ["../../design-system/src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  /* design-system's own ambient plotly.js-dist-min declaration
     (../../design-system/src/types/plotly.d.ts) isn't picked up automatically the
     way tsconfig.app.json's build seems to; included explicitly so test files that
     transitively reach SyChart/Gauge don't need @types/plotly.js-dist-min re-declared. */
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**/*.ts",
    "vitest.config.ts",
    "../../design-system/src/types/*.d.ts"
  ]
}
